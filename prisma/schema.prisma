generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  INTERVIEW
  DOCUMENT_VERIFICATION
  APPROVED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  PASSED
  FAILED
  RESCHEDULED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_PROOF
  CERTIFICATE
  EXPERIENCE_PROOF
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

model User {
  id           String    @id @default(uuid())
  name         String?
  mobile       String?   @unique
  gender       Gender?
  birthDate    DateTime?
  birthTime    String?
  occupation   String?
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  refreshToken String?   @db.Text

  wallet        UserWallet?
  payments      Payment[]
  paymentOrders PaymentOrder[]
  sessions      Session[]
  Intake        Intake[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phoneNo  String  @unique
  password String?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  approvedAstrologers Astrologer[] @relation("AdminApprovedAstrologers")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  astrologers Astrologer[]
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  permissions RolePermission[]
  admins      Admin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Astrologer {
  id         String @id @default(uuid())
  name       String
  profilePic String
  experience Int
  email      String @unique
  contactNo  String
  about      String

  languages String[]
  skills    String[]

  approvalStatus ApprovalStatus @default(PENDING)
  approvedById   String?
  approvedBy     Admin?         @relation("AdminApprovedAstrologers", fields: [approvedById], references: [id])

  addresses   Address[]
  experiences ExperiencePlatform[]
  interviews  Interview[]
  documents   AstrologerDocument[]

  wallet   AstrologerWallet?
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin?   @relation(fields: [adminId], references: [id])
  adminId   String?
}

model Address {
  id Int @id @default(autoincrement())

  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  street  String
  city    String
  state   String
  country String
  pincode String
}

model ExperiencePlatform {
  id Int @id @default(autoincrement())

  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  platformName String
  yearsWorked  Int
}

model Interview {
  id Int @id @default(autoincrement())

  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  roundNumber     Int
  interviewerName String
  scheduledAt     DateTime

  status InterviewStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
}

model RechargePack {
  id    String @id @default(uuid())
  name  String
  price Float
  coins Int

  transactions WalletTransaction[]
  payments     Payment[]
}

model UserWallet {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  balanceCoins Int @default(0)
  lockedCoins  Int @default(0)

  transactions WalletTransaction[]
}

model AstrologerWallet {
  id String @id @default(uuid())

  astrologerId String     @unique
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  balanceCoins Int @default(0)

  transactions WalletTransaction[]
}

model WalletTransaction {
  id String @id @default(uuid())

  userWalletId String?
  userWallet   UserWallet? @relation(fields: [userWalletId], references: [id])

  astrologerWalletId String?
  astrologerWallet   AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])

  rechargePackId String?
  rechargePack   RechargePack? @relation(fields: [rechargePackId], references: [id])

  coins Int
  type  TransactionType

  createdAt DateTime @default(now())
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  type   SessionType
  status SessionStatus

  createdAt DateTime @default(now())
}

model Payment {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount Float

  status         PaymentStatus
  rechargePackId String
  rechargePack   RechargePack  @relation(fields: [rechargePackId], references: [id])
}

model PaymentOrder {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount Float
}

model Intake {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  astrologerId String

  name       String
  mobile     String
  birthPlace String
}

// added by ammy 
model AstrologerDocument {
  id Int @id @default(autoincrement())

  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  documentType DocumentType
  documentUrl  String

  status DocumentStatus @default(PENDING)

  verifiedBy String?
  verifiedAt DateTime?
  remarks    String?

  createdAt DateTime @default(now())

  @@unique([astrologerId, documentType])
  @@index([astrologerId])
  @@index([status])
}
