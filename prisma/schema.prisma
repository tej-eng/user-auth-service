generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String?
  mobile        String?        @unique
  gender        Gender?
  birthDate     DateTime?
  birthTime     String?
  occupation    String?
  isActive      Boolean        @default(true)
  isDeleted     Boolean        @default(false)
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Intake        Intake[]
  payments      Payment[]
  paymentOrders PaymentOrder[]
  sessions      Session[]
  wallet        UserWallet?
}

model Admin {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phoneNo  String  @unique
  password String?

  isActive Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  astrologers         Astrologer[]
  approvedAstrologers Astrologer[] @relation("AdminApprovedAstrologers")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  admins      Admin[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model Astrologer {
  id             String               @id @default(uuid())
  name           String
  profilePic     String
  experience     Int
  email          String               @unique
  contactNo      String
  about          String
  price          Float
  rating         Float
  languages      String[]
  skills         String[]
  approvalStatus ApprovalStatus       @default(PENDING)
  approvedById   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  adminId        String?
  addresses      Address[]
  admin          Admin?               @relation(fields: [adminId], references: [id])
  approvedBy     Admin?               @relation("AdminApprovedAstrologers", fields: [approvedById], references: [id])
  documents      AstrologerDocument[]
  wallet         AstrologerWallet?
  experiences    ExperiencePlatform[]
  interviews     Interview[]
  sessions       Session[]
}

model Address {
  id           Int        @id @default(autoincrement())
  astrologerId String
  street       String
  city         String
  state        String
  country      String
  pincode      String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model ExperiencePlatform {
  id           Int        @id @default(autoincrement())
  astrologerId String
  platformName String
  yearsWorked  Int
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model Interview {
  id              Int             @id @default(autoincrement())
  astrologerId    String
  roundNumber     Int
  interviewerName String
  scheduledAt     DateTime
  status          InterviewStatus @default(SCHEDULED)
  createdAt       DateTime        @default(now())
  astrologer      Astrologer      @relation(fields: [astrologerId], references: [id])
}

model RechargePack {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  talktime    Int
  isActive    Boolean @default(true)

  payments     Payment[]
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balanceCoins Int                 @default(0)
  lockedCoins  Int                 @default(0)
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model AstrologerWallet {
  id           String              @id @default(uuid())
  astrologerId String              @unique
  balanceCoins Int                 @default(0)
  astrologer   Astrologer          @relation(fields: [astrologerId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id                 String            @id @default(uuid())
  userWalletId       String?
  astrologerWalletId String?
  rechargePackId     String?
  coins              Int
  type               TransactionType
  createdAt          DateTime          @default(now())
  astrologerWallet   AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])
  rechargePack       RechargePack?     @relation(fields: [rechargePackId], references: [id])
  userWallet         UserWallet?       @relation(fields: [userWalletId], references: [id])
}

model Session {
  id           String        @id @default(uuid())
  userId       String
  astrologerId String
  type         SessionType
  status       SessionStatus
  createdAt    DateTime      @default(now())
  astrologer   Astrologer    @relation(fields: [astrologerId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  amount         Float
  status         PaymentStatus
  rechargePackId String
  rechargePack   RechargePack  @relation(fields: [rechargePackId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model PaymentOrder {
  id     String @id @default(uuid())
  userId String
  amount Float
  user   User   @relation(fields: [userId], references: [id])
}

model Intake {
  id           String @id @default(uuid())
  userId       String
  astrologerId String
  name         String
  mobile       String
  birthPlace   String
  user         User   @relation(fields: [userId], references: [id])
}

model AstrologerDocument {
  id           Int            @id @default(autoincrement())
  astrologerId String
  documentType DocumentType
  documentUrl  String
  status       DocumentStatus @default(PENDING)
  verifiedBy   String?
  verifiedAt   DateTime?
  remarks      String?
  createdAt    DateTime       @default(now())
  astrologer   Astrologer     @relation(fields: [astrologerId], references: [id])

  @@unique([astrologerId, documentType])
  @@index([astrologerId])
  @@index([status])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  INTERVIEW
  DOCUMENT_VERIFICATION
  APPROVED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  PASSED
  FAILED
  RESCHEDULED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_PROOF
  CERTIFICATE
  EXPERIENCE_PROOF
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

// ammmmyyyyyyyyyyyyyyyyyy

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  applicable   String?
  type         String
  status       Boolean  @default(true)
  visibility   String
  percentage   Float?
  max_discount Float?
  redeem_limit Int?
  start_date   DateTime
  end_date     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// new astrologer application 
model AstrologerApplication {
  id String @id @default(uuid())

  name        String
  phoneNumber String
  email       String
  dob         DateTime
  gender      String
  languages   String[]
  skills      String[]
  experience  Int
  about       String?

  status ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
