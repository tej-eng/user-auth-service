generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String?
  mobile        String?        @unique
  gender        Gender?
  birthDate     DateTime?
  birthTime     String?
  occupation    String?
  isActive      Boolean        @default(true)
  isDeleted     Boolean        @default(false)
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Intake        Intake[]
  payments      Payment[]
  paymentOrders PaymentOrder[]
  sessions      Session[]
  wallet        UserWallet?
  Review        Review[]
}

model Admin {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phoneNo  String  @unique
  password String?

  isActive Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  admins       Admin[]
  permissions  RolePermission[]
  staffMembers Staff[]
}

model Permission {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  roles            RolePermission[]
  staffPermissions StaffPermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model Astrologer {
  id           String              @id @default(uuid())
  name         String
  displayName  String
  profilePic   String?
  gender       Gender
  email        String              @unique
  contactNo    String
  password     String
  experience   Int
  aboutEnglish String
  languages    String[]
  skills       String[]
  problems     String[]
  pricing      AstrologerPricing[]

  tags             String
  vtags            String
  approvalStatus   ApprovalStatus               @default(PENDING)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  refreshToken     String?
  approvedById     String?
  createdById      String?
  addresses        Address[]
  approvedBy       Staff?                       @relation("ApprovedByRelation", fields: [approvedById], references: [id])
  createdBy        Staff?                       @relation("CreatedAstrologers", fields: [createdById], references: [id])
  documents        AstrologerDocument[]
  rejectionHistory AstrologerRejectionHistory[]
  wallet           AstrologerWallet?

  experiences            ExperiencePlatform[]
  intakes                Intake[]
  interviews             Interview[]
  reviews                Review[]
  sessions               Session[]
  astrologerCommissionId String?

  applications AstrologerApplication[]
}

model AstrologerRejectionHistory {
  id           Int            @id @default(autoincrement())
  astrologerId String
  stage        RejectionStage
  reason       String
  rejectedBy   String
  createdAt    DateTime       @default(now())
  astrologer   Astrologer     @relation(fields: [astrologerId], references: [id])

  @@index([astrologerId])
  @@index([stage])
}

model Review {
  id           String     @id @default(uuid())
  userId       String
  astrologerId String
  sessionId    String?    @unique
  rating       Int
  comment      String?
  userName     String?
  astroName    String?
  createdAt    DateTime   @default(now())
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
  session      Session?   @relation(fields: [sessionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([astrologerId])
}

model Interview {
  id              Int             @id @default(autoincrement())
  astrologerId    String
  roundNumber     Int
  interviewerName String
  scheduledAt     DateTime
  status          InterviewStatus @default(SCHEDULED)
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  astrologer      Astrologer      @relation(fields: [astrologerId], references: [id])

  @@unique([astrologerId, roundNumber])
  @@index([astrologerId])
  @@index([scheduledAt])
  @@index([status])
}

model Address {
  id           Int        @id @default(autoincrement())
  astrologerId String
  street       String
  city         String
  state        String
  country      String
  pincode      String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model ExperiencePlatform {
  id           Int        @id @default(autoincrement())
  astrologerId String
  platformName String
  yearsWorked  Int
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model RechargePack {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  talktime    Int
  isActive    Boolean @default(true)

  payments     Payment[]
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balanceCoins Int                 @default(0)
  lockedCoins  Int                 @default(0)
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model AstrologerWallet {
  id           String              @id @default(uuid())
  astrologerId String              @unique
  balanceCoins Int                 @default(0)
  astrologer   Astrologer          @relation(fields: [astrologerId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id                 String            @id @default(uuid())
  userWalletId       String?
  astrologerWalletId String?
  rechargePackId     String?
  coins              Int
  type               TransactionType
  createdAt          DateTime          @default(now())
  astrologerWallet   AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])
  rechargePack       RechargePack?     @relation(fields: [rechargePackId], references: [id])
  userWallet         UserWallet?       @relation(fields: [userWalletId], references: [id])
}

model Session {
  id           String        @id @default(uuid())
  userId       String
  astrologerId String
  type         SessionType
  status       SessionStatus
  createdAt    DateTime      @default(now())
  astrologer   Astrologer    @relation(fields: [astrologerId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  Review       Review?
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  amount         Float
  status         PaymentStatus
  rechargePackId String
  rechargePack   RechargePack  @relation(fields: [rechargePackId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model PaymentOrder {
  id     String @id @default(uuid())
  userId String
  amount Float
  user   User   @relation(fields: [userId], references: [id])
}

model Intake {
  id           String     @id @default(uuid())
  userId       String
  astrologerId String
  name         String
  mobile       String
  birthPlace   String
  user         User       @relation(fields: [userId], references: [id])
  Astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model AstrologerDocument {
  id           Int            @id @default(autoincrement())
  astrologerId String
  documentType DocumentType
  documentUrl  String
  status       DocumentStatus @default(PENDING)
  verifiedBy   String?
  verifiedAt   DateTime?
  remarks      String?
  createdAt    DateTime       @default(now())
  astrologer   Astrologer     @relation(fields: [astrologerId], references: [id])

  @@unique([astrologerId, documentType])
  @@index([astrologerId])
  @@index([status])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  ID_PROOF
  CERTIFICATE
  EXPERIENCE_PROOF
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

// ammmmyyyyyyyyyyyyyyyyyy

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  applicable   String?
  type         String
  status       Boolean  @default(true)
  visibility   String
  percentage   Float?
  max_discount Float?
  redeem_limit Int?
  start_date   DateTime
  end_date     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// new astrologer application 

// new astrologer application 
model AstrologerApplication {
  id                   String            @id @default(uuid())
  name                 String
  phoneNumber          String            @unique
  email                String?           @unique
  dob                  DateTime
  gender               Gender
  languages            String[]
  skills               String[]
  experience           Int
  about                String?
  address              String
  pincode              String?
  applicationStatus    ApplicationStatus @default(PENDING)
  interviewStatus      InterviewStatus   @default(PENDING)
  documentStatus       DocumentStatus    @default(PENDING)
  approvalStatus       ApprovalStatus    @default(PENDING)
  interviewerId        String?
  interviewer          Staff?            @relation("InterviewerRelation", fields: [interviewerId], references: [id])
  interviewDate        DateTime?
  interviewTime        String?
  round                Int?
  interviewRemarks     String?
  interviewTakenAt     DateTime?
  interviewScheduledAt DateTime?
  staffId              String?
  staff                Staff?            @relation("StaffRelation", fields: [staffId], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  astrologerId         String?
  astrologer           Astrologer?       @relation(fields: [astrologerId], references: [id])

  kycDetail KycDetail?

  @@index([applicationStatus])
  @@index([interviewStatus])
  @@index([approvalStatus])
}

model Staff {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  roleId       String
  departmentId String

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔥 APPLICATION FLOW
  interviews          AstrologerApplication[] @relation("InterviewerRelation")
  createdApplications AstrologerApplication[] @relation("StaffRelation")
  permissions         StaffPermission[]
  // 🔥 APPROVED ASTROLOGERS
  approvedAstrologers Astrologer[]            @relation("ApprovedByRelation")
  createdAstrologers  Astrologer[]            @relation("CreatedAstrologers")
  department          Department              @relation(fields: [departmentId], references: [id])
  role                Role                    @relation(fields: [roleId], references: [id])
}

model Department {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)
  staffMembers Staff[]
}

model StaffPermission {
  id           String     @id @default(uuid())
  staffId      String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, permissionId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InterviewStatus {
  PENDING
  SCHEDULED
  PASSED
  REJECTED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model KycDetail {
  id String @id @default(uuid())

  // 🔗 relation
  astrologerApplicationId String                @unique
  application             AstrologerApplication @relation(fields: [astrologerApplicationId], references: [id])

  // 🏦 BANK
  accountHolderName String?
  accountNumber     String?
  bankName          String?
  ifsc              String?
  branchName        String?
  panNumber         String?

  // 📄 DOCS
  profileImage  String?
  aadhaarImage  String?
  panImage      String?
  passbookImage String?

  // 🔥 status
  status DocumentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(uuid())

  staffId String
  message String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())
}

model PricingConfig {
  id String @id @default(uuid())

  isFirstOfferEnabled Boolean @default(true)
  firstChatPrice      Int     @default(0)
  firstCallPrice      Int     @default(0)

  isSecondOfferEnabled Boolean @default(false)
  secondChatPrice      Int     @default(0)
  secondCallPrice      Int     @default(0)
}

enum OfferType {
  FREE
  ONE_RUPEE
  ORIGINAL
}

model UserOfferUsage {
  id     String @id @default(uuid())
  userId String @unique

  visitCount Int @default(0)

  usedFirst  Boolean @default(false)
  usedSecond Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AstrologerPricing {
  id                String      @id @default(uuid())
  astrologerId      String
  type              PricingType
  price             Float
  offerPrice        Float?
  commissionPercent Float?
  isActive          Boolean     @default(true)

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])

  @@unique([astrologerId, type])
}

enum PricingType {
  CHAT
  CALL
  VIDEO
  AUDIO
}
