generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String?
  mobile        String?        @unique
  gender        Gender?
  birthDate     DateTime?
  birthTime     String?
  occupation    String?
  isActive      Boolean        @default(true)
  isDeleted     Boolean        @default(false)
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Intake        Intake[]
  payments      Payment[]
  paymentOrders PaymentOrder[]
  sessions      Session[]
  wallet        UserWallet?
}

model Admin {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phoneNo  String  @unique
  password String?

  isActive Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  admins       Admin[]
  permissions  RolePermission[]
  staffMembers Staff[]
}

model Permission {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  roles            RolePermission[]
  staffPermissions StaffPermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model Astrologer {
  id String @id @default(uuid())

  name        String
  email       String   @unique
  phoneNumber String   @unique
  gender      Gender
  languages   String[]
  skills      String[]
  experience  Int
  about       String?

  profilePic String?
  price      Float?
  rating     Float   @default(0)

  isActive Boolean @default(true)

  approvedById String?
  approvedBy   Staff?  @relation("ApprovedByRelation", fields: [approvedById], references: [id])

  applicationId String                @unique
  application   AstrologerApplication @relation(fields: [applicationId], references: [id])

  // 🔥 ADD THESE (missing reverse relations)
  addresses   Address[]
  experiences ExperiencePlatform[]
  wallet      AstrologerWallet?
  sessions    Session[]
  documents   AstrologerDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id           Int        @id @default(autoincrement())
  astrologerId String
  street       String
  city         String
  state        String
  country      String
  pincode      String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model ExperiencePlatform {
  id           Int        @id @default(autoincrement())
  astrologerId String
  platformName String
  yearsWorked  Int
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model RechargePack {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  talktime    Int
  isActive    Boolean @default(true)

  payments     Payment[]
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balanceCoins Int                 @default(0)
  lockedCoins  Int                 @default(0)
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model AstrologerWallet {
  id           String              @id @default(uuid())
  astrologerId String              @unique
  balanceCoins Int                 @default(0)
  astrologer   Astrologer          @relation(fields: [astrologerId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id                 String            @id @default(uuid())
  userWalletId       String?
  astrologerWalletId String?
  rechargePackId     String?
  coins              Int
  type               TransactionType
  createdAt          DateTime          @default(now())
  astrologerWallet   AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])
  rechargePack       RechargePack?     @relation(fields: [rechargePackId], references: [id])
  userWallet         UserWallet?       @relation(fields: [userWalletId], references: [id])
}

model Session {
  id           String        @id @default(uuid())
  userId       String
  astrologerId String
  type         SessionType
  status       SessionStatus
  createdAt    DateTime      @default(now())
  astrologer   Astrologer    @relation(fields: [astrologerId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  amount         Float
  status         PaymentStatus
  rechargePackId String
  rechargePack   RechargePack  @relation(fields: [rechargePackId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model PaymentOrder {
  id     String @id @default(uuid())
  userId String
  amount Float
  user   User   @relation(fields: [userId], references: [id])
}

model Intake {
  id           String @id @default(uuid())
  userId       String
  astrologerId String
  name         String
  mobile       String
  birthPlace   String
  user         User   @relation(fields: [userId], references: [id])
}

model AstrologerDocument {
  id           Int            @id @default(autoincrement())
  astrologerId String
  documentType DocumentType
  documentUrl  String
  status       DocumentStatus @default(PENDING)
  verifiedBy   String?
  verifiedAt   DateTime?
  remarks      String?
  createdAt    DateTime       @default(now())
  astrologer   Astrologer     @relation(fields: [astrologerId], references: [id])

  @@unique([astrologerId, documentType])
  @@index([astrologerId])
  @@index([status])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  ID_PROOF
  CERTIFICATE
  EXPERIENCE_PROOF
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

// ammmmyyyyyyyyyyyyyyyyyy

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  description  String?
  applicable   String?
  type         String
  status       Boolean  @default(true)
  visibility   String
  percentage   Float?
  max_discount Float?
  redeem_limit Int?
  start_date   DateTime
  end_date     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// new astrologer application 

// new astrologer application 
model AstrologerApplication {
  id String @id @default(uuid())

  // 🔹 BASIC INFO
  name        String
  phoneNumber String   @unique
  email       String   @unique
  dob         DateTime
  gender      Gender
  languages   String[]
  skills      String[]
  experience  Int
  about       String?

  // 🔥 WORKFLOW STATES
  applicationStatus ApplicationStatus @default(PENDING)
  interviewStatus   InterviewStatus   @default(PENDING)
  documentStatus    DocumentStatus    @default(PENDING)
  approvalStatus    ApprovalStatus    @default(PENDING)

  // 🔹 INTERVIEW DETAILS
  interviewerId String?
  interviewer   Staff?  @relation("InterviewerRelation", fields: [interviewerId], references: [id])

  interviewDate DateTime?
  interviewTime String?
  round         Int?

  // 🔹 CREATED / HANDLED BY STAFF
  staffId String?
  staff   Staff?  @relation("StaffRelation", fields: [staffId], references: [id])

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  astrologer Astrologer?

  @@index([applicationStatus])
  @@index([interviewStatus])
  @@index([approvalStatus])
}

model Staff {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  roleId       String
  departmentId String

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔥 APPLICATION FLOW
  interviews          AstrologerApplication[] @relation("InterviewerRelation")
  createdApplications AstrologerApplication[] @relation("StaffRelation")
  permissions         StaffPermission[]
  // 🔥 APPROVED ASTROLOGERS
  approvedAstrologers Astrologer[]            @relation("ApprovedByRelation")

  department Department @relation(fields: [departmentId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])
}

model Department {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)
  staffMembers Staff[]
}

model StaffPermission {
  id           String     @id @default(uuid())
  staffId      String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, permissionId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InterviewStatus {
  PENDING
  SCHEDULED
  PASSED
  REJECTED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
